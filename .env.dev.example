APP_NAME=HCR2 Records API
APP_VERSION=0.1.0
ENVIRONMENT=development

DB_HOST=127.0.0.1
DB_PORT=54329
DB_NAME=hcr2_dev
DB_USER=hcr2_dev
DB_PASS=hcr2_dev_password
DATABASE_URL=postgresql://hcr2_dev:hcr2_dev_password@127.0.0.1:54329/hcr2_dev

AUTH_SHARED_SECRET=dev-only-hcr2-secret
ALLOWED_DISCORD_IDS=dev-admin
API_KEYS=dev-api-key

HCAPTCHA_SITE_KEY=dev-hcaptcha-site-key
HCAPTCHA_SECRET_KEY=dev-hcaptcha-secret-key

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
